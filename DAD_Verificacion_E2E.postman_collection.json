{
  "info": {
    "name": "DAD - Verificacion E2E (Fases 1-10)",
    "description": "Flujo de verificacion completo. Ejecutalo en ORDEN con el Collection Runner (Run collection). Cada request lleva tests automaticos. Re-ejecutable: genera dni/codigo/email unicos y encadena tokens e ids. Requiere todos los servicios arriba y usuarios admin/admin123 y alumno1/alum123.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "host", "value": "localhost" },
    { "key": "portGateway", "value": "8080" },
    { "key": "portConfig", "value": "8888" },
    { "key": "portEureka", "value": "8761" },
    { "key": "portTaller", "value": "8083" },
    { "key": "jwt", "value": "" },
    { "key": "jwtAlumno", "value": "" },
    { "key": "instructorId", "value": "" },
    { "key": "alumnoId", "value": "" },
    { "key": "alumnoId2", "value": "" },
    { "key": "tallerId", "value": "" },
    { "key": "tallerLleno", "value": "" }
  ],
  "item": [
    {
      "name": "F1-2 | Config Server sirve config",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('trae datasource', () => pm.expect(pm.response.text()).to.include('datasource'));" ] } } ],
      "request": { "method": "GET", "header": [], "url": { "raw": "http://{{host}}:{{portConfig}}/ms-gestion-instructor/dev", "protocol": "http", "host": ["{{host}}"], "port": "{{portConfig}}", "path": ["ms-gestion-instructor", "dev"] } }
    },
    {
      "name": "F1-2 | Eureka lista apps",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('hay servicios', () => pm.expect(pm.response.text()).to.include('MS-GESTION'));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Accept", "value": "application/json" } ], "url": { "raw": "http://{{host}}:{{portEureka}}/eureka/apps", "protocol": "http", "host": ["{{host}}"], "port": "{{portEureka}}", "path": ["eureka", "apps"] } }
    },
    {
      "name": "F4 | Gateway expone rutas",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('incluye instructor', () => pm.expect(pm.response.text()).to.include('ms-gestion-instructor'));" ] } } ],
      "request": { "method": "GET", "header": [], "url": { "raw": "http://{{host}}:{{portGateway}}/actuator/gateway/routes", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["actuator", "gateway", "routes"] } }
    },
    {
      "name": "F8 | Login ADMIN (guarda jwt)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "const j = pm.response.json();", "pm.test('token', () => pm.expect(j.token).to.be.a('string').and.not.empty);", "pm.test('rol ADMIN', () => pm.expect(j.rol).to.eql('ADMIN'));", "pm.collectionVariables.set('jwt', j.token);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{ \"username\": \"admin\", \"password\": \"admin123\" }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/auth/login", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "auth", "login"] } }
    },
    {
      "name": "F8 | Login ALUMNO (guarda jwtAlumno)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "const j = pm.response.json();", "pm.test('rol ALUMNO', () => pm.expect(j.rol).to.eql('ALUMNO'));", "pm.collectionVariables.set('jwtAlumno', j.token);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{ \"username\": \"alumno1\", \"password\": \"alum123\" }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/auth/login", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "auth", "login"] } }
    },
    {
      "name": "F8 | Validate token ADMIN",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "const j = pm.response.json();", "pm.test('valido', () => pm.expect(j.valido).to.eql(true));", "pm.test('rol ADMIN', () => pm.expect(j.rol).to.eql('ADMIN'));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/auth/validate", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "auth", "validate"] } }
    },
    {
      "name": "F9 | GET instructores SIN token -> 401",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('401', () => pm.response.to.have.status(401));" ] } } ],
      "request": { "method": "GET", "header": [], "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores"] } }
    },
    {
      "name": "F9 | GET instructores con token -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtAlumno}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores"] } }
    },
    {
      "name": "F9 | POST instructor como ALUMNO -> 403",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('dni', String(Math.floor(10000000 + Math.random()*89999999)));" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('403', () => pm.response.to.have.status(403));" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtAlumno}}" } ], "body": { "mode": "raw", "raw": "{ \"dni\": \"{{dni}}\", \"nombres\": \"No\", \"apellidos\": \"Permitido\", \"especialidad\": \"X\", \"email\": \"no@upeu.edu.pe\" }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores"] } }
    },
    {
      "name": "F3/F9 | POST instructor como ADMIN -> 201",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('dni', String(Math.floor(10000000 + Math.random()*89999999)));", "pm.variables.set('email', 'instructor' + Date.now() + '@upeu.edu.pe');" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));", "const j = pm.response.json();", "pm.collectionVariables.set('instructorId', j.id);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"dni\": \"{{dni}}\", \"nombres\": \"Benjamin\", \"apellidos\": \"Reyna\", \"especialidad\": \"Microservicios\", \"email\": \"{{email}}\" }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores"] } }
    },
    {
      "name": "F3 | GET instructor por id -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('id coincide', () => pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('instructorId'))));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores/{{instructorId}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores", "{{instructorId}}"] } }
    },
    {
      "name": "F3 | Validacion DNI invalido -> 400",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('400', () => pm.response.to.have.status(400));", "pm.test('validationErrors', () => pm.expect(pm.response.json().validationErrors).to.not.be.null);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"dni\": \"123\", \"nombres\": \"\", \"apellidos\": \"X\", \"especialidad\": \"X\", \"email\": \"malo\" }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores"] } }
    },
    {
      "name": "F3 | No encontrado -> 404",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('404', () => pm.response.to.have.status(404));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores/999999", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores", "999999"] } }
    },
    {
      "name": "F3 | POST alumno (ADMIN) -> 201",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('codigo', 'A' + Date.now());", "pm.variables.set('email', 'alumno' + Date.now() + '@upeu.edu.pe');" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));", "pm.collectionVariables.set('alumnoId', pm.response.json().id);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"codigo\": \"{{codigo}}\", \"nombres\": \"Fernando\", \"apellidos\": \"Esteban\", \"email\": \"{{email}}\", \"ciclo\": 5 }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/alumnos", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "alumnos"] } }
    },
    {
      "name": "F10 | POST alumno 2 (ADMIN) -> 201",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('codigo', 'B' + Date.now());", "pm.variables.set('email', 'alumno2' + Date.now() + '@upeu.edu.pe');" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));", "pm.collectionVariables.set('alumnoId2', pm.response.json().id);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"codigo\": \"{{codigo}}\", \"nombres\": \"Segundo\", \"apellidos\": \"Alumno\", \"email\": \"{{email}}\", \"ciclo\": 4 }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/alumnos", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "alumnos"] } }
    },
    {
      "name": "F3 | POST taller (ADMIN) -> 201",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('codigo', 'T' + Date.now());" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));", "pm.collectionVariables.set('tallerId', pm.response.json().id);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"codigo\": \"{{codigo}}\", \"nombre\": \"Taller Demo E2E\", \"descripcion\": \"Verificacion\", \"cupoMaximo\": 5 }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres"] } }
    },
    {
      "name": "F4 | GET talleres via Gateway -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres"] } }
    },
    {
      "name": "F5 | Asignar instructor (Feign) -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('instructor asignado', () => pm.expect(pm.response.json().instructorId).to.eql(Number(pm.collectionVariables.get('instructorId'))));" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres/{{tallerId}}/asignar-instructor/{{instructorId}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres", "{{tallerId}}", "asignar-instructor", "{{instructorId}}"] } }
    },
    {
      "name": "F5 | Detalle completo (Feign) -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('instructor compuesto', () => pm.expect(pm.response.json().instructor).to.not.be.null);" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres/{{tallerId}}/detalle-completo", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres", "{{tallerId}}", "detalle-completo"] } }
    },
    {
      "name": "F7 | Balanceo whoami -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('reporta puerto', () => pm.expect(pm.response.json().puerto).to.exist);", "console.log('Instancia:', pm.response.json().puerto);" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/instructores/whoami", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "instructores", "whoami"] } }
    },
    {
      "name": "F6 | Resiliencia circuitbreakers -> 200",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));" ] } } ],
      "request": { "method": "GET", "header": [], "url": { "raw": "http://{{host}}:{{portTaller}}/actuator/circuitbreakers", "protocol": "http", "host": ["{{host}}"], "port": "{{portTaller}}", "path": ["actuator", "circuitbreakers"] } }
    },
    {
      "name": "F10 | Saga matricular alumno -> 201",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{jwtAlumno}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres/{{tallerId}}/matricular-alumno/{{alumnoId}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres", "{{tallerId}}", "matricular-alumno", "{{alumnoId}}"] } }
    },
    {
      "name": "F10 | Contador alumno subio (>=1)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('talleresInscritos >= 1', () => pm.expect(pm.response.json().talleresInscritos).to.be.at.least(1));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/alumnos/{{alumnoId}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "alumnos", "{{alumnoId}}"] } }
    },
    {
      "name": "F10 | Crear taller LLENO (cupo=1) -> 201",
      "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.variables.set('codigo', 'L' + Date.now());" ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));", "pm.collectionVariables.set('tallerLleno', pm.response.json().id);" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "body": { "mode": "raw", "raw": "{ \"codigo\": \"{{codigo}}\", \"nombre\": \"Taller Lleno\", \"descripcion\": \"cupo 1\", \"cupoMaximo\": 1 }" }, "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres"] } }
    },
    {
      "name": "F10 | Ocupar el unico cupo -> 201",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.to.have.status(201));" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{jwtAlumno}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres/{{tallerLleno}}/matricular-alumno/{{alumnoId}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres", "{{tallerLleno}}", "matricular-alumno", "{{alumnoId}}"] } }
    },
    {
      "name": "F10 | Contador alumno2 ANTES (0)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('empieza en 0', () => pm.expect(pm.response.json().talleresInscritos).to.eql(0));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/alumnos/{{alumnoId2}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "alumnos", "{{alumnoId2}}"] } }
    },
    {
      "name": "F10 | Matricular alumno2 en lleno -> 409 (compensa)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('409 revertida', () => pm.response.to.have.status(409));", "pm.test('mensaje revertida', () => pm.expect(pm.response.json().message).to.include('revertida'));" ] } } ],
      "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{jwtAlumno}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/talleres/{{tallerLleno}}/matricular-alumno/{{alumnoId2}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "talleres", "{{tallerLleno}}", "matricular-alumno", "{{alumnoId2}}"] } }
    },
    {
      "name": "F10 | Contador alumno2 DESPUES (sigue 0)",
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('200', () => pm.response.to.have.status(200));", "pm.test('compensacion OK sigue 0', () => pm.expect(pm.response.json().talleresInscritos).to.eql(0));" ] } } ],
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ], "url": { "raw": "http://{{host}}:{{portGateway}}/api/alumnos/{{alumnoId2}}", "protocol": "http", "host": ["{{host}}"], "port": "{{portGateway}}", "path": ["api", "alumnos", "{{alumnoId2}}"] } }
    }
  ]
}
